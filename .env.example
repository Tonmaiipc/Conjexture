# ContextPool — copy this to .env and fill in your values
# Letta's setup config
LETTA_ALLOW_PRIVATE_IP=true

# Cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Local providers
LMSTUDIO_BASE_URL=http://host.docker.internal:1234
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Letta base url
LETTA_BASE_URL=http://localhost:8283

# Letta auth — set SECURE=true and a password if exposing beyond localhost
SECURE=false
LETTA_SERVER_PASSWORD=

# Letta auth — set SECURE=true and a password if exposing beyond localhost
SECURE=false
LETTA_SERVER_PASSWORD=

# Letta DB config — only required if using the built-in DB (not recommended for production)
LETTA_DB_USERNAME=letta
LETTA_DB_PASSWORD=letta
LETTA_DB_NAME=letta
LETTA_DB_URI=postgresql://letta:letta@letta-db:5432/letta

# Mem0 DB config — only required if using the built-in DB (not recommended for production)
MEM0_DB_USERNAME=mem0
MEM0_DB_PASSWORD=mem0
MEM0_DB_NAME=mem0
MEM0_DB_URI=postgresql://mem0:mem0@mem0-db:5432/mem0

# mem0 config
MEM0_ORG_ID=ctxpool-org
MEM0_LLM_BASE_URL=https://openrouter.ai/api/v1
MEM0_LLM_MODEL=deepseek/deepseek-v4-flash
MEM0_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
MEM0_EMBEDDING_MODEL=openai/text-embedding-3-small
MEM0_LLM_API_KEY=
QDRANT_HOST=ctxpool-qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=ctxpool

# searxng config
SEARXNG_BASE_URL=http://searxng:8080

# Slack Integration config
SLACK_MCP_XOXB_TOKEN=xoxb-...
SLACK_MCP_XOXP_TOKEN=xoxp-...
SLACK_MCP_API_KEY=mocked-secret-token-for-dev

# Jira Integration config
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
ATLASSIAN_OAUTH_REDIRECT_URI=http://localhost:8080/callback
