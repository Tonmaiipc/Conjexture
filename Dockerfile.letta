FROM letta/letta:latest
RUN /app/.venv/bin/python3 -m ensurepip && \
    /app/.venv/bin/python3 -m pip install mem0ai && \
    /app/.venv/bin/python3 -m pip install 'protobuf<6.0' && \
    /app/.venv/bin/python3 -m pip install fastembed && \
    /app/.venv/bin/python3 -m pip install 'mem0ai[nlp]'
COPY patches/fix_deepseek.py /tmp/fix_deepseek.py
RUN /app/.venv/bin/python3 /tmp/fix_deepseek.py
COPY patches/fix_url_validation.py /tmp/fix_url_validation.py
RUN /app/.venv/bin/python3 /tmp/fix_url_validation.py